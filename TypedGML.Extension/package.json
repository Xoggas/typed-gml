{
  "name": "typedgml-vscode",
  "displayName": "TypedGML",
  "description": "Syntax highlighting for TypedGML (.tgml) files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "typedgml",
        "aliases": [
          "TypedGML",
          "tgml"
        ],
        "extensions": [
          ".tgml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "typedgml",
        "scopeName": "source.tgml",
        "path": "./syntaxes/typedgml.tmLanguage.json"
      }
    ]
  }
}
