{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TypedGML",
  "scopeName": "source.tgml",
  "fileTypes": [
    "tgml"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#raw-line"
    },
    {
      "include": "#decorator"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#namespace-using"
    },
    {
      "include": "#type-declarations"
    },
    {
      "include": "#member-declarations"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#keywords-control"
    },
    {
      "include": "#keywords-other"
    },
    {
      "include": "#accessor-keywords"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#qualified-types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-call"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.tgml",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.tgml"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.tgml"
            }
          }
        },
        {
          "name": "comment.line.double-slash.tgml",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.tgml"
            }
          }
        }
      ]
    },
    "raw-line": {
      "comment": "RAW_LINE : '#' ~[\\r\\n]* ;",
      "name": "meta.embedded.raw-gml.tgml",
      "match": "^\\s*#.*$",
      "captures": {
        "0": {
          "name": "markup.raw.inline.tgml"
        }
      }
    },
    "decorator": {
      "comment": "@Decorator or @Namespace.Decorator(args)",
      "name": "meta.decorator.tgml",
      "match": "(@)([a-zA-Z_][a-zA-Z_0-9]*(?:\\.[a-zA-Z_][a-zA-Z_0-9]*)*)",
      "captures": {
        "1": {
          "name": "punctuation.decorator.tgml"
        },
        "2": {
          "name": "entity.name.tag.decorator.tgml"
        }
      }
    },
    "strings": {
      "name": "string.quoted.double.tgml",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.tgml"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.tgml"
        }
      },
      "patterns": [
        {
          "include": "#string-escape"
        }
      ]
    },
    "string-escape": {
      "name": "constant.character.escape.tgml",
      "match": "\\\\(?:[\"'\\\\bfnrt]|u[0-9a-fA-F]{4})"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.tgml",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.tgml",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.float.tgml",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.tgml",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.tgml",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.tgml",
          "match": "\\bnull\\b"
        }
      ]
    },
    "namespace-using": {
      "patterns": [
        {
          "name": "meta.namespace.tgml",
          "match": "\\b(namespace|using)\\s+([a-zA-Z_][a-zA-Z_0-9]*(?:\\.[a-zA-Z_][a-zA-Z_0-9]*)*)",
          "captures": {
            "1": {
              "name": "keyword.other.namespace.tgml"
            },
            "2": {
              "name": "entity.name.namespace.tgml"
            }
          }
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "meta.class.tgml",
          "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
          "captures": {
            "1": {
              "name": "storage.type.class.tgml"
            },
            "2": {
              "name": "entity.name.type.class.tgml"
            }
          }
        },
        {
          "name": "meta.struct.tgml",
          "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
          "captures": {
            "1": {
              "name": "storage.type.struct.tgml"
            },
            "2": {
              "name": "entity.name.type.struct.tgml"
            }
          }
        },
        {
          "name": "meta.enum.tgml",
          "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
          "captures": {
            "1": {
              "name": "storage.type.enum.tgml"
            },
            "2": {
              "name": "entity.name.type.enum.tgml"
            }
          }
        },
        {
          "name": "meta.interface.tgml",
          "match": "\\b(interface)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
          "captures": {
            "1": {
              "name": "storage.type.interface.tgml"
            },
            "2": {
              "name": "entity.name.type.interface.tgml"
            }
          }
        },
        {
          "name": "meta.delegate.tgml",
          "match": "\\b(delegate)\\s+([a-zA-Z_][a-zA-Z_0-9]*(?:\\.[a-zA-Z_][a-zA-Z_0-9]*)*(?:\\s*<[^\\r\\n(){};]+>)?(?:\\s*\\[\\])*)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
          "captures": {
            "1": {
              "name": "storage.type.delegate.tgml"
            },
            "2": {
              "name": "storage.type.return-type.tgml"
            },
            "3": {
              "name": "entity.name.type.delegate.tgml"
            }
          }
        }
      ]
    },
    "member-declarations": {
      "patterns": [
        {
          "name": "meta.method.declaration.tgml",
          "match": "\\b([a-zA-Z_][a-zA-Z_0-9]*(?:\\.[a-zA-Z_][a-zA-Z_0-9]*)*(?:\\s*<[^\\r\\n(){};]+>)?(?:\\s*\\[\\])*)\\s+([a-zA-Z_][a-zA-Z_0-9]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "storage.type.return-type.tgml"
            },
            "2": {
              "name": "entity.name.function.tgml"
            }
          }
        },
        {
          "name": "meta.property.declaration.tgml",
          "match": "\\b([a-zA-Z_][a-zA-Z_0-9]*(?:\\.[a-zA-Z_][a-zA-Z_0-9]*)*(?:\\s*<[^\\r\\n(){};]+>)?(?:\\s*\\[\\])*)\\s+([a-zA-Z_][a-zA-Z_0-9]*)\\s*(?=\\{|\\[)",
          "captures": {
            "1": {
              "name": "storage.type.property-type.tgml"
            },
            "2": {
              "name": "variable.other.member.tgml"
            }
          }
        },
        {
          "name": "entity.name.function.constructor.tgml",
          "match": "\\bconstructor\\b"
        }
      ]
    },
    "modifiers": {
      "name": "storage.modifier.tgml",
      "match": "\\b(?:public|protected|private|static|global|readonly|const|abstract|sealed|virtual|override)\\b"
    },
    "keywords-control": {
      "name": "keyword.control.tgml",
      "match": "\\b(?:if|else|while|for|repeat|switch|case|default|break|continue|return|with|try|catch|finally)\\b"
    },
    "keywords-other": {
      "patterns": [
        {
          "name": "keyword.other.declaration.tgml",
          "match": "\\b(?:delegate|operator|implicit|explicit)\\b"
        },
        {
          "name": "keyword.operator.new.tgml",
          "match": "\\bnew\\b"
        },
        {
          "name": "keyword.operator.type.tgml",
          "match": "\\b(?:is|as|typeof|nameof|base)\\b"
        },
        {
          "name": "keyword.operator.logical.tgml",
          "match": "\\b(?:and|or|not)\\b"
        }
      ]
    },
    "accessor-keywords": {
      "name": "keyword.other.accessor.tgml",
      "match": "\\b(?:get|set|field|value)\\b"
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "storage.type.builtin.tgml",
          "match": "\\b(?:bool|number|long|string|ptr|void|var)\\b"
        }
      ]
    },
    "qualified-types": {
      "patterns": [
        {
          "name": "entity.name.type.namespace-qualified.tgml",
          "match": "\\b[A-Z][a-zA-Z_0-9]*(?:\\.[A-Z][a-zA-Z_0-9]*)+\\b"
        },
        {
          "name": "entity.name.type.tgml",
          "match": "\\b[A-Z][a-zA-Z_0-9]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.tgml",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.comparison.tgml",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.arrow.tgml",
          "match": "=>"
        },
        {
          "name": "keyword.operator.assignment.tgml",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.bitwise.tgml",
          "match": "<<|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.relational.tgml",
          "match": "<|>"
        },
        {
          "name": "keyword.operator.arithmetic.tgml",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ternary.tgml",
          "match": "\\?"
        }
      ]
    },
    "function-call": {
      "comment": "nameId LPAREN argList? RPAREN",
      "name": "entity.name.function.tgml",
      "match": "\\b(?!(?:if|else|while|for|repeat|switch|case|default|break|continue|return|with|try|catch|finally|new|typeof|nameof|default|get|set|constructor)\\b)([a-zA-Z_][a-zA-Z_0-9]*)(?=\\s*\\()"
    }
  }
}
