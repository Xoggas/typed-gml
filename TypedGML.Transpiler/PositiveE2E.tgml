        var explicitBool = default(bool);
        var explicitString = default(string);
    }
}

public class PropertyFeature
{
    private number _maxHealth;

    public number Health { get; private set; }

    public number Clamped
    {
        get => field;
        set => field = Math.Clamp(value, 0, 100);
    }

    public number Percent
    {
        get
        {
            return (Health * 100) / _maxHealth;
        }
        set
        {
            Health = (value * _maxHealth) / 100;
        }
    }

    public constructor()
    {
        _maxHealth = 200;
        Health = 100;
        Clamped = 150;
        Percent = 50;
    }
}

public class ControlFlowFeature
{
    public number Run(number count)
    {
        number total = 0;

        for (var i = 0; i < count; i = i + 1)
        {
            if (i == 2)
            {
                continue;
            }

            total += i;
        }

        while (total < 10)
        {
            total += 1;
            if (total == 8)
            {
                break;
            }
        }

        repeat (2)
        {
            total += 1;
        }

        switch (count)
        {
            case 0:
                total = 1;
            case 1:
                total = 2;
            default:
                total += count;
        }

        try
        {
            total += 1;
        }
        catch (System.Object error)
        {
            total = 0;
        }
        finally
        {
            total += 1;
        }

        return total;
    }
}

public class OperatorFeature
{
    public void Run()
    {
        var left = new FeaturePoint(1, 2);
        var right = new FeaturePoint(3, 4);
        var combined = left + right;
        var negated = -combined;
        number total = combined;
        var casted = (FeaturePoint)total;
    }
}

