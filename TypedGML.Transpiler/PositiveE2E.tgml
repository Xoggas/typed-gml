public class PrimitiveAndAliasFeature
{
    public void Run()
    {
        number count = 1;
        Number aliasNumber = 2;
        long aliasLong = 3;
        Bool aliasBool = true;
        String aliasString = "Feature";

        var total = count + aliasNumber + aliasLong;
        var compare = total >= 3;
        var logical = aliasBool and compare;
        var lower = aliasString.ToLower();
        var length = lower.Length;
        var label = String.FromNumber(length);
    }
}

