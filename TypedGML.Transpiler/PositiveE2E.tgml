public class DelegateFeature
{
    private System.Action<number> _changed;
    private System.Func<number, number> _map;
    private System.Predicate<number> _predicate;

    public constructor()
    {
        _changed = null;
        _map = null;
        _predicate = null;
    }

    public void Run()
    {
        _changed = OnChanged;
        _changed += OnChanged;
        _changed -= OnChanged;
        _map = Double;
        _predicate = IsPositive;

        _changed(1);
        var mapped = _map(4);
        var passed = _predicate(mapped);
    }

    public void OnChanged(number value)
    {
    }

    public number Double(number value)
    {
        return value * 2;
    }

    public bool IsPositive(number value)
    {
        return value > 0;
    }
}

public class CollectionsFeature
{
    public void Run()
    {
        var list = new System.Collections.List<number>();
        list.Add(1);
        list.AddRange([2, 3]);
        list[0] = 5;
        var first = list[0];
        var hasFive = list.Contains(5);
        var index = list.IndexOf(3);
        var removed = list.Remove(2);
        var removedAt = list.RemoveAt(0);

        var stack = new System.Collections.Stack<string>();
        stack.Push("a");
        var peeked = stack.Peek();
        var popped = stack.Pop();

        var queue = new System.Collections.Queue<number>();
        queue.Enqueue(1);
        var front = queue.Peek();
        var dequeued = queue.Dequeue();

        System.Collections.Dictionary<string, number> map = {
            "one": 1,
            "two": 2
        };
        map["three"] = 3;
        var value = map.GetOrDefault("missing", 0);
        var keys = map.KeysToArray();
        var values = map.ValuesToArray();
        map.Destroy();
    }
}

