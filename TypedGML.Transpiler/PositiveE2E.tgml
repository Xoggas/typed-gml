namespace E2E.Positive;

public interface INamed
{
    string Name { get; }
}

public interface IWorker
{
    number Work(number value);
}

public enum TestMode
{
    None = 0,
    Active = 1,
    Disabled = 2
}

public struct FeaturePoint
{
    public number X;
    public number Y;

    public constructor(number x = 0, number y = 0)
    {
        X = x;
        Y = y;
    }

    public static FeaturePoint operator +(FeaturePoint left, FeaturePoint right)
    {
        return new FeaturePoint(left.X + right.X, left.Y + right.Y);
    }

    public static FeaturePoint operator -(FeaturePoint value)
    {
        return new FeaturePoint(-value.X, -value.Y);
    }

    public static implicit operator number(FeaturePoint value)
    {
        return value.X + value.Y;
    }

    public static explicit operator FeaturePoint(number value)
    {
        return new FeaturePoint(value, value);
    }
}

public class NamedThing : INamed
{
    public string Name { get; private set; }

    public constructor(string name = "thing")
    {
        Name = name;
    }
}

public class Box<T : INamed>
{
    public constructor()
    {
    }

    public string LabelOf(T value)
    {
        return value.Name;
    }
}

public abstract class WorkerBase : IWorker
{
    protected number _offset;

    public constructor(number offset = 1)
    {
        _offset = offset;
    }

    public abstract number Work(number value);

    protected number AddOffset(number value)
    {
        return value + _offset;
    }
}

public class WorkerChild : WorkerBase
{
    public constructor(number offset = 2) : base(offset)
    {
    }

    public override number Work(number value)
    {
        return AddOffset(value) * 2;
    }
}

public class ObjectProbe
{
    @NativeProperty("speed")
    public number Speed { get; set; }

    public number ManagedSpeed { get; set; }

    public constructor()
    {
        Speed = 1;
        ManagedSpeed = 2;
    }
}

@Object("obj_E2E_BaseMover")
public class BaseMover : System.GameObject
{
    public number Counter { get; protected set; }

    public constructor(number x, number y, string layer) : base(x, y, layer)
    {
        Counter = 0;
    }

    public virtual void Tick()
    {
        Counter += 1;
        Translate(1, 0);
    }

    @NativeEvent("Step")
    public virtual void HandleStep()
    {
        Tick();
    }
}

@Object("obj_E2E_ChildMover")
public class ChildMover : BaseMover
{
    public constructor(number x, number y, string layer, number seed) : base(x, y, layer)
    {
        Counter = seed;
    }

    public override void Tick()
    {
        base.Tick();
        Counter += 5;
    }

    public override void HandleStep()
    {
        base.HandleStep();
        Tick();
    }
}

