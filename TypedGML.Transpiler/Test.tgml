namespace Game.Systems;

public interface IDestructible
{
    void TakeDamage(int amount);
    int Health { get; set; }
}

public interface ILoggable
{
    string GetLog();
}

public enum Faction
{
    None = 0,
    Alliance = 1,
    Horde = 2
}

public abstract class Entity : IDestructible, ILoggable
{
    public int Health { get; set; }
    public string Name { get; set; }
    public bool IsAlive { get; set; }

    public constructor(string name, int health)
    {
        Name = name;
        Health = health;
        IsAlive = health > 0;
    }

    public abstract void TakeDamage(int amount);

    public string GetLog()
    {
        return Name;
    }

    public void Heal(int amount)
    {
        int next = Health + amount;
        if (next > 100)
        {
            Health = 100;
        }
        else
        {
            Health = next;
        }
        IsAlive = Health > 0;
    }
}

public sealed class Player : Entity
{
    public int Level { get; set; }
    public Faction Side { get; set; }

    public constructor(string name, int health, int level) : base(name, health)
    {
        Level = level;
        Side = Faction.Alliance;
    }

    public override void TakeDamage(int amount)
    {
        int reduced = Health - amount;
        if (reduced < 0)
        {
            Health = 0;
            IsAlive = false;
        }
        else
        {
            Health = reduced;
            IsAlive = reduced > 0;
        }
    }

    public bool CanLevelUp()
    {
        return IsAlive and Level < 99;
    }

    public void LevelUp()
    {
        if (CanLevelUp())
        {
            Level = Level + 1;
            Heal(10);
        }
    }
}

// ── Overloading test ────────────────────────────────────────────────────────

public class Weapon
{
    public string Name { get; set; }
    public int Damage { get; set; }

    // Constructor overload 1: just a name, default damage 10
    public constructor(string name)
    {
        Name = name;
        Damage = 10;
    }

    // Constructor overload 2: name + explicit damage
    public constructor(string name, int damage)
    {
        Name = name;
        Damage = damage;
    }

    // Method overload 1: scale damage by integer factor
    public int Scale(int factor)
    {
        return Damage * factor;
    }

    // Method overload 2: get a labelled description string
    public string Scale(string prefix)
    {
        return prefix;
    }
}

// ── 3-way method overload: int / string / struct ─────────────────────────────

public class Logger
{
    public void Log(int code)
    {
        int x = code;
    }

    public void Log(string message)
    {
        string s = message;
    }

    public void Log(Player player)
    {
        string s = player.Name;
    }
}

// ── Child with overloaded constructors calling different parent overloads ─────

public class Vehicle
{
    public string Model { get; set; }
    public int Speed { get; set; }

    public constructor(string model)
    {
        Model = model;
        Speed = 60;
    }

    public constructor(string model, int speed)
    {
        Model = model;
        Speed = speed;
    }
}

public class Car : Vehicle
{
    public int Doors { get; set; }

    // Calls Vehicle(string)
    public constructor(string model) : base(model)
    {
        Doors = 4;
    }

    // Calls Vehicle(string, int)
    public constructor(string model, int speed, int doors) : base(model, speed)
    {
        Doors = doors;
    }
}

