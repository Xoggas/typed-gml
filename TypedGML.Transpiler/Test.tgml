@Object("obj_Player")
public class Player : GameObject
{
    public string Name { get; set; }

    public constructor(string name, number x, number y) : base(x, y, "layer_default")
    {
        Name = name;
    }
    
    public constructor(string name) : base(0, 0, "layer_default")
    {
        Name = name;
    }
}

public static class PlayerFactory
{
    public static Player CreatePlayer(string name, number x, number y)
    {
        return new Player(name, x, y);
    }
    
    public static Player CreatePlayer(string name)
    {
        return new Player(name);
    }
}