namespace Tests;
using TypedGML.Core;
using TypedGML.Collections;
using TypedGML.Utils;
using TypedGML.GameObjects;
using TypedGML.Assets;

public enum Color { Red = 0, Green = 1, Blue = 2 }

public interface IDescribable {
    string Describe();
}

public abstract class Shape : IDescribable {
    public abstract number Area { get; }
    public abstract string Describe();
    public override string ToString() { return Describe(); }
}

public class Circle : Shape {
    private number _radius;
    public Circle(number radius) { _radius = radius; }
    public override number Area { get { return Math.PI * _radius * _radius; } }
    public override string Describe() { return "Circle(" + _radius + ")"; }
}

public struct Point {
    public number X;
    public number Y;
    public Point(number x, number y) { X = x; Y = y; }
    public static number Distance(Point a, Point b) {
        var dx = b.X - a.X;
        var dy = b.Y - a.Y;
        return Math.Sqrt(dx * dx + dy * dy);
    }
    public override string ToString() { return "(" + X + ", " + Y + ")"; }
}

public class Counter {
    public static number Total = 0;
    private number _count;

    static Counter() {
        Total = 0;
    }

    public Counter() { _count = 0; }

    public void Increment() {
        _count += 1;
        Counter.Total += 1;
    }

    public number Value { get { return _count; } }
}

public delegate void Changed(number newValue);

@Object("OBJ_Player")
public class Player : GameObject {
    // Health is already declared in GameObject as @NativeProperty("health").
    // MaxHp is our own field — different name to avoid shadowing.
    public number MaxHp = 100;

    public Player(number x, number y, string layer) { }

    public override void OnCreate() {
        MaxHp = 100;
        Debug.Log("Player created");
    }

    public override void OnStep() {
        if (Health <= 0) {
            Debug.Log("Player dead");
        }
    }
}
